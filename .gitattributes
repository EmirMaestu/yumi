# Forzar LF en archivos que corren en Linux (el deploy los ejecuta en el VPS).
# Sin esto, en Windows el checkout podría meter CRLF y romper bash/systemd.
*.sh            text eol=lf
*.service       text eol=lf
*.timer         text eol=lf
deploy/rsync-excludes.txt   text eol=lf
deploy/yumi-deploy.sudoers  text eol=lf
